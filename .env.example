# ── LLM API ───────────────────────────────────────────────────────────────────
# Required: OpenAI-compatible API key for the task generation and filter pipeline
OPENAI_API_KEY=sk-...

# Optional: custom base URL (e.g. Azure OpenAI, local vLLM, or other providers)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Anthropic API key (used for Claude-based teacher rollout filtering)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Environment backend ───────────────────────────────────────────────────────
# Select the VM/container provider for task execution.
# "e2b"     — e2b cloud sandboxes (requires E2B_API_KEY below)
# "docker"  — local Docker containers (no cloud credentials needed)
# "aliyun"  — Aliyun ECS VMs (default, requires ALIYUN_* credentials below)
# ENV_BACKEND=e2b

# ── E2B backend (cloud sandboxes — no local Docker/VM needed) ─────────────────
# Requires an E2B account: https://e2b.dev
# Install SDK: pip install e2b-desktop
# E2B_API_KEY=e2b_...
# E2B_ENV_TEMPLATE=cua-gym-desktop     # e2b template ID; run provision/e2b/build_cua_gym_template.py first
# E2B_ENV_TIMEOUT=3600                # sandbox timeout in seconds (default: 3600)

# ── Docker backend (local, no cloud credentials needed) ───────────────────────
# Build the image once:  bash provision/docker/build_image.sh
# DOCKER_ENV_IMAGE=cua-gym-desktop:latest
# DOCKER_ENV_PLATFORM=linux/amd64
# DOCKER_ENV_SHM_SIZE=2g
# DOCKER_ENV_MEMORY=           # e.g. 8g (optional)
# DOCKER_ENV_CPUS=             # e.g. 4  (optional)
# DOCKER_ENV_READY_TIMEOUT=90  # seconds to wait for desktop

# ── Aliyun ECS (cloud VM provider — default when ENV_BACKEND is unset) ────────
# Required only when ENV_BACKEND=aliyun (or ENV_BACKEND is not set)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=ap-southeast-1
ALIYUN_IMAGE_ID=
ALIYUN_INSTANCE_TYPE=ecs.g8a.xlarge
ALIYUN_VSWITCH_ID=
ALIYUN_SECURITY_GROUP_ID=
ALIYUN_RESOURCE_GROUP_ID=
ALIYUN_USE_PRIVATE_IP=1

# ── OSWorld (required only for Aliyun backend) ────────────────────────────────
# Path to OSWorld-RL installation on the machine running the orchestrator
OSWORLD_DIR=~/OSWorld-RL
OSWORLD_VENV=~/.venvs/osworld-py312

# ── SSH Gateway (optional, for remote orchestration) ─────────────────────────
# SSH_GATEWAY_HOST=
# SSH_GATEWAY_PORT=22
# SSH_GATEWAY_USER=root
# SSH_GATEWAY_OSWORLD_DIR=~/OSWorld-RL
# SSH_GATEWAY_VENV=~/.venvs/osworld-py312
